layout {
  background-color "#121318"

  focus-ring {
    active-color "#b5c4ff"
    inactive-color "#8f909a"
    urgent-color   "#ffb4ab"
  }

  border {
    active-color   "#b5c4ff"
    inactive-color "#8f909a"
    urgent-color   "#ffb4ab"
  }

  shadow {
    color "#00000070"
  }

  tab-indicator {
    active-color   "#b5c4ff"
    inactive-color "#8f909a"
    urgent-color   "#ffb4ab"
  }

  insert-hint {
    color "#b5c4ff80"
  }
}

overview {
  backdrop-color "#121318"
}
