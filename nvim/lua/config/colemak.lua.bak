-- movement remaps
vim.cmd("noremap j n")
vim.cmd("noremap e k")
vim.cmd("noremap i l")
vim.cmd("noremap n j")

vim.cmd("nnoremap U I")
vim.cmd("nnoremap gg dd")
vim.cmd("nnoremap G D")

-- searching
vim.cmd("nnoremap f f")
vim.cmd("nnoremap t t")
vim.cmd("nnoremap F F")
vim.cmd("nnoremap T T")
vim.cmd("nnoremap o ;")

-- editing
vim.cmd("nnoremap s d")
vim.cmd("nnoremap l u")

vim.cmd("nnoremap m o")
vim.cmd("nnoremap M O")

vim.cmd("nnoremap d g")
vim.cmd("nnoremap dd gg")

vim.cmd("noremap j y")
