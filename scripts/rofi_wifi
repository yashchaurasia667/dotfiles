#!/usr/bin/env bash

# Scan and refresh networks
nmcli device wifi rescan 2>/dev/null
sleep 1

# Build list of saved SSIDs
saved_ssids=()
while IFS= read -r profile; do
  ssid=$(nmcli -g 802-11-wireless.ssid connection show "$profile" 2>/dev/null | tr -d '\r\n')
  [[ -n "$ssid" && "$ssid" != "--" ]] && saved_ssids+=("$ssid")
done < <(nmcli -g NAME connection show | tr -d '\r')

is_known() {
  local target
  target=$(echo "$1" | tr -d '\r\n')
  for s in "${saved_ssids[@]}"; do
    [[ "$s" == "$target" ]] && return 0
  done
  return 1
}

get_profile() {
  local target
  target=$(echo "$1" | tr -d '\r\n')
  while IFS= read -r profile; do
    ssid=$(nmcli -g 802-11-wireless.ssid connection show "$profile" 2>/dev/null | tr -d '\r\n')
    [[ "$ssid" == "$target" ]] && echo "$profile" && return
  done < <(nmcli -g NAME connection show | tr -d '\r')
}

# Get available networks with BSSID and FREQ, no deduplication yet
# Use --escape no to avoid backslash-escaping colons in SSIDs
raw=$(nmcli --escape no -t -f SSID,BSSID,SIGNAL,SECURITY,FREQ device wifi list 2>/dev/null)

[ -z "$raw" ] && notify-send "WiFi" "No networks found." && exit 1

# Build display list and SSID/BSSID lookup maps keyed by display string
declare -A line_to_ssid
declare -A line_to_bssid
menu=""
declare -A seen_ssid_band  # deduplicate by SSID+band

while IFS= read -r line; do
  # Fields: SSID:BSSID:SIGNAL:SECURITY:FREQ
  ssid=$(echo "$line" | cut -d: -f1)
  bssid=$(echo "$line" | cut -d: -f2-7)  # BSSID has colons: aa:bb:cc:dd:ee:ff
  signal=$(echo "$line" | cut -d: -f8)
  security=$(echo "$line" | cut -d: -f9)
  freq=$(echo "$line" | cut -d: -f10)

  [[ -z "$ssid" ]] && continue

    # Determine band from frequency
    band="2.4G"
    [[ "$freq" == *"5"* ]] && band="5G"

    # Deduplicate by SSID+band, keep highest signal (first seen after sort)
    key="${ssid}|${band}"
    [[ -n "${seen_ssid_band[$key]}" ]] && continue
    seen_ssid_band["$key"]=1

    lock="🔓"
    [[ -n "$security" && "$security" != "--" ]] && lock="🔒"

    if is_known "$ssid"; then
      marker="✓ saved"
    else
      marker="✦ new"
    fi

    display=$(printf "%3d%%  %s  [%s]  %s  %s" "$signal" "$lock" "$band" "$ssid" "$marker")
    line_to_ssid["$display"]="$ssid"
    line_to_bssid["$display"]="$bssid"
    menu+="$display"$'\n'
  done < <(echo "$raw" | sort -t: -k3 -rn)

  [ -z "$menu" ] && notify-send "WiFi" "No networks found." && exit 1

# Show rofi menu
chosen=$(echo "$menu" | rofi -dmenu -i -p "" -mesg "Select a network to connect")
[ -z "$chosen" ] && exit 0

ssid="${line_to_ssid[$chosen]}"
bssid="${line_to_bssid[$chosen]}"
lock=$(echo "$chosen" | awk '{print $2}')

[ -z "$ssid" ] && notify-send "WiFi" "Error: could not parse SSID." && exit 1

notify-send "WiFi" "Connecting to $ssid…" --icon=network-wireless 2>/dev/null

connect() {
  local cmd_output
  if cmd_output=$(eval "$1" 2>&1); then
    notify-send "WiFi" "Connected to $ssid" --icon=network-wireless 2>/dev/null
  else
    notify-send "WiFi" "Failed: $cmd_output" --icon=network-wireless-offline 2>/dev/null
  fi
}

if is_known "$ssid"; then
  profile=$(get_profile "$ssid")
  # Connect via BSSID to ensure correct band (2.4 vs 5GHz)
  connect "nmcli device wifi connect '$bssid' name '$profile'"
elif [[ "$lock" == "🔓" ]]; then
  connect "nmcli device wifi connect '$bssid'"
else
  password=$(rofi -dmenu -p "󰌆  Password for $ssid" -password < /dev/null)
  [ -z "$password" ] && exit 0
  connect "nmcli device wifi connect '$bssid' password '$password'"
fi
